## Flask / app config
SECRET_KEY=change-me-to-a-long-random-string
FLASK_DEBUG=0
# Публичный тест с домашнего ПК (ngrok / Cloudflare Tunnel):
# FLASK_HOST=0.0.0.0
# FLASK_PORT=5000
# PUBLIC_BASE_URL=https://xxxx.ngrok-free.app
# TRUST_PROXY=1
# SESSION_COOKIE_SECURE=1

## Database
# SQLite (файл в instance/): sqlite:///instance/crm.db
# PostgreSQL: postgresql+psycopg2://crm:password@localhost:5432/crm
# Перенос: docs/POSTGRES_MIGRATION_RU.md  и  scripts/migrate_to_postgres.ps1
DATABASE_URL=sqlite:///instance/crm.db

## DeepSeek AI
DEEPSEEK_API_KEY=

## Telegram (входящие сообщения — вебхук)
# Токен от @BotFather — нужен для setWebhook и будущей отправки ответов
TELEGRAM_BOT_TOKEN=
# Если с ПК не уходят ответы бота (таймаут api.telegram.org), укажите прокси/VPN:
# TELEGRAM_HTTPS_PROXY=http://127.0.0.1:7890
# Секрет вебхука (тот же, что передаёте в setWebhook как secret_token)
TELEGRAM_WEBHOOK_SECRET=

## WhatsApp Cloud API (Meta) — вебхук и исходящие
# Строка, которую вы задаёте в Meta при настройке Callback URL (Verify token)
WA_VERIFY_TOKEN=
# App Secret из Meta (Settings → Basic) — для проверки X-Hub-Signature-256
WA_APP_SECRET=
# Permanent access token для отправки сообщений из CRM
WA_ACCESS_TOKEN=
# Опционально, если не задан Phone number ID в разделе Интеграции
WA_PHONE_NUMBER_ID=
